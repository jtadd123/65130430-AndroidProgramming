<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center_vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="MENU CHỌN DANH SÁCH"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="30dp"
        android:textColor="#3F51B5"/>

    <Button
        android:id="@+id/btn_vat_lieu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Xem Danh Sách Vật Liệu"
        android:layout_marginBottom="10dp"/>

    <Button
        android:id="@+id/btn_mon_an"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Xem Danh Mục Món Ăn"
        android:layout_marginBottom="10dp"/>

    <Button
        android:id="@+id/btn_tinh"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Xem Tỉnh Thành Việt Nam"/>

</LinearLayout>
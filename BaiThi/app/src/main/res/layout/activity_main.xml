<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5"
    tools:context=".MainActivity">

    <!-- Thanh tieu de phia tren -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1565C0"
        android:padding="24dp"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📱 BÀI THI GIỮA KỲ 2"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nguyễn Văn Đạt - 65130430"
            android:textSize="15sp"
            android:textColor="#BBDEFB"/>
    </LinearLayout>

    <!-- Phu de huong dan -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chọn chức năng bên dưới để bắt đầu:"
        android:textSize="14sp"
        android:textColor="#666666"
        android:padding="16dp"
        android:background="#E3F2FD"/>

    <!-- Cac nut chuc nang -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <!-- Nut Chuc nang 1: Tinh chu vi va dien tich -->
        <Button
            android:id="@+id/btnChucNang1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📐 Chức năng 1: Tính Chu Vi và Diện Tích"
            android:textSize="15sp"
            android:layout_marginBottom="14dp"
            android:backgroundTint="#1565C0"
            android:textColor="#FFFFFF"
            android:padding="16dp"/>

        <!-- Nut Chuc nang 2: Danh sach tinh thanh pho -->
        <Button
            android:id="@+id/btnChucNang2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📍 Chức năng 2: Danh Sách Tỉnh/Thành Phố"
            android:textSize="15sp"
            android:layout_marginBottom="14dp"
            android:backgroundTint="#2E7D32"
            android:textColor="#FFFFFF"
            android:padding="16dp"/>

        <!-- Nut Chuc nang 3: Diem du lich Nha Trang -->
        <Button
            android:id="@+id/btnChucNang3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🏖️ Chức năng 3: Điểm Du Lịch Nha Trang"
            android:textSize="15sp"
            android:layout_marginBottom="14dp"
            android:backgroundTint="#E65100"
            android:textColor="#FFFFFF"
            android:padding="16dp"/>

        <!-- Nut Chuc nang 4: Thong tin ca nhan -->
        <Button
            android:id="@+id/btnChucNang4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="👤 Chức năng 4: Thông Tin Cá Nhân"
            android:textSize="15sp"
            android:backgroundTint="#6A1B9A"
            android:textColor="#FFFFFF"
            android:padding="16dp"/>

    </LinearLayout>

</LinearLayout>
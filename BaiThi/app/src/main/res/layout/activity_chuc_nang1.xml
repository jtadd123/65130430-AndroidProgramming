<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5"
    tools:context=".ChucNang1Activity">

    <!-- Thanh tieu de phia tren -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1565C0"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Nut quay lai -->
        <Button
            android:id="@+id/btnQuayLai"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Quay lại"
            android:textSize="13sp"
            android:backgroundTint="#0D47A1"
            android:textColor="#FFFFFF"/>

        <!-- Tieu de -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📐 Tính Chu Vi - Diện Tích"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layout_marginEnd="48dp"/>
    </LinearLayout>

    <!-- Noi dung chinh -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Nhap chieu dai -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chiều dài (m):"
            android:textSize="16sp"
            android:textColor="#333333"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/edtChieuDai"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nhập chiều dài"
            android:inputType="numberDecimal"
            android:padding="14dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="20dp"/>

        <!-- Nhap chieu rong -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chiều rộng (m):"
            android:textSize="16sp"
            android:textColor="#333333"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/edtChieuRong"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nhập chiều rộng"
            android:inputType="numberDecimal"
            android:padding="14dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="28dp"/>

        <!-- Nut tinh toan -->
        <Button
            android:id="@+id/btnTinhToan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TÍNH TOÁN"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#1565C0"
            android:textColor="#FFFFFF"
            android:padding="14dp"
            android:layout_marginBottom="24dp"/>

        <!-- Hien thi ket qua -->
        <TextView
            android:id="@+id/txtKetQua"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="18sp"
            android:textColor="#1B5E20"
            android:textStyle="bold"
            android:padding="16dp"
            android:background="#E8F5E9"
            android:lineSpacingExtra="4dp"
            android:visibility="gone"/>

    </LinearLayout>

</LinearLayout>

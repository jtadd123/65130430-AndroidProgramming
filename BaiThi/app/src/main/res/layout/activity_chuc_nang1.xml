<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F5F5F5"
    tools:context=".ChucNang1Activity">

    <!-- Nut quay lai -->
    <Button
        android:id="@+id/btnQuayLai"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="← Quay lại"
        android:textSize="14sp"
        android:backgroundTint="#78909C"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp"/>

    <!-- Tieu de -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tính Chu Vi và Diện Tích"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1565C0"
        android:layout_gravity="center"
        android:layout_marginBottom="32dp"/>

    <!-- Nhap chieu dai -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chiều dài (m):"
        android:textSize="16sp"
        android:textColor="#333333"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/edtChieuDai"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nhập chiều dài"
        android:inputType="numberDecimal"
        android:padding="12dp"
        android:background="@android:drawable/edit_text"
        android:layout_marginBottom="16dp"/>

    <!-- Nhap chieu rong -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chiều rộng (m):"
        android:textSize="16sp"
        android:textColor="#333333"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/edtChieuRong"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nhập chiều rộng"
        android:inputType="numberDecimal"
        android:padding="12dp"
        android:background="@android:drawable/edit_text"
        android:layout_marginBottom="24dp"/>

    <!-- Nut tinh toan -->
    <Button
        android:id="@+id/btnTinhToan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="TÍNH TOÁN"
        android:textSize="16sp"
        android:backgroundTint="#1565C0"
        android:textColor="#FFFFFF"
        android:padding="14dp"
        android:layout_marginBottom="24dp"/>

    <!-- Hien thi ket qua -->
    <TextView
        android:id="@+id/txtKetQua"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="18sp"
        android:textColor="#1B5E20"
        android:textStyle="bold"
        android:padding="16dp"
        android:background="#E8F5E9"
        android:visibility="gone"/>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5"
    tools:context=".ChucNang3Activity">

    <!-- Thanh tieu de phia tren -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#E65100"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Nut quay lai -->
        <Button
            android:id="@+id/btnQuayLai"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Quay lại"
            android:textSize="13sp"
            android:backgroundTint="#BF360C"
            android:textColor="#FFFFFF"/>

        <!-- Tieu de -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Du Lịch Nha Trang"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layout_marginEnd="48dp"/>
    </LinearLayout>

    <!-- Phu de -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🏖️ Top 5 điểm du lịch nổi tiếng"
        android:textSize="14sp"
        android:textColor="#555555"
        android:padding="12dp"
        android:background="#FFF3E0"/>

    <!-- Danh sach diem du lich -->
    <ListView
        android:id="@+id/lvDiemDuLich"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:divider="#E0E0E0"
        android:dividerHeight="1dp"
        android:padding="8dp"
        android:clipToPadding="false"/>

</LinearLayout>

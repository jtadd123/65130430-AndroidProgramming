<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="85dp"
    android:orientation="horizontal">
    <ImageView
        android:id="@+id/img_anhDaiDien"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="#E6E6AD"
        />
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:paddingLeft="5dp"
        android:background="#E6E6AD"
        >
        <TextView
            android:id="@+id/tvTenMonAn"
            android:layout_width="match_parent"
            android:layout_height="25dp"
            android:text="Món thứ nhất"
            android:textSize="18sp"
            android:textColor="#7F9567"
            android:textStyle="bold"

            />
        <TextView
            android:id="@+id/tvDonGia"
            android:layout_width="match_parent"
            android:layout_height="25dp"
            android:textStyle="bold"
            android:textColor="#B52205"
            android:text="200000đ"
            android:textSize="16sp"

            />
        <TextView
            android:id="@+id/tvMoTa"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:text="Nội dung mô t ở đây"
            android:textSize="15sp"
            />
    </LinearLayout>
</LinearLayout>